---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Contact | ${SITE_TITLE}`}
			description="Contact FEM Design Solutions to discuss FEM, design, and manufacturing consulting."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<h1>Request engineering consulting</h1>
				<p>
					Share your product challenge, target timeline, and current bottlenecks. We can support
					specific analyses or broader design and manufacturing strategy.
				</p>
				<div class="card">
					<p><strong>Email:</strong> consult@femdesignsolutions.com</p>
					<p><strong>Focus areas:</strong> FEM, design reviews, DFM, and manufacturing troubleshooting.</p>
					<p><strong>Typical response time:</strong> 1 business day</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
