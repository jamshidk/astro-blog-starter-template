---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">FEM • Product Design • Manufacturing</p>
				<h1>Engineering consulting for smarter products and faster launches.</h1>
				<p>
					FEM Design Solutions supports your team from concept validation to manufacturing readiness.
					We combine simulation, practical design, and process knowledge to reduce risk and speed up
					your development cycle.
				</p>
				<div class="cta-row">
					<a class="button" href="/contact">Book a consultation</a>
					<a class="button button-secondary" href="/about">See our approach</a>
				</div>
			</section>

			<section>
				<h2>Consulting services</h2>
				<div class="grid cards">
					<article class="card">
						<h3>Finite Element Modeling (FEM)</h3>
						<p>
							Structural, thermal, and fatigue simulation to validate designs before expensive
							prototypes.
						</p>
					</article>
					<article class="card">
						<h3>Design Engineering</h3>
						<p>
							Design solutions that balance performance, reliability, material constraints, and
							cost targets.
						</p>
					</article>
					<article class="card">
						<h3>Manufacturing Techniques</h3>
						<p>
							Guidance on DFM, process selection, tolerancing, and production problem-solving for
							scale-up.
						</p>
					</article>
				</div>
			</section>

			<section>
				<h2>Industries we support</h2>
				<p>
					We work with teams in industrial equipment, consumer products, automotive components, and
					R&D-heavy startups. Explore technical notes on our <a href="/blog">blog</a>.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
