---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`About | ${SITE_TITLE}`}
			description="Learn how FEM Design Solutions delivers simulation-driven engineering support."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<h1>About FEM Design Solutions</h1>
				<p>
					FEM Design Solutions is a consulting website and engineering practice focused on finite
					element analysis, design optimization, manufacturing techniques, and design solutions for
					complex product challenges.
				</p>
			</section>
			<section>
				<h2>How we work</h2>
				<ol>
					<li><strong>Problem definition:</strong> Clarify loads, constraints, failure modes, and requirements.</li>
					<li><strong>Simulation & iteration:</strong> Build FEM models and refine concepts using data-driven decisions.</li>
					<li><strong>Design for manufacturing:</strong> Align geometry, material, and tolerances with your process capabilities.</li>
					<li><strong>Implementation support:</strong> Provide documentation and technical guidance through launch.</li>
				</ol>
			</section>
		</main>
		<Footer />
	</body>
</html>
